const amqp = require('amqplib');

async function adminReceiver() {
    try {
        const connection = await amqp.connect('amqp://guest:guest@127.0.0.1:5672');
        const channel = await connection.createChannel();

        const exchange = 'announcements';

        await channel.assertExchange(exchange, 'fanout', { durable: false });

        // Create unique queue for Admin
        const q = await channel.assertQueue('', { exclusive: true });

        // Bind to exchange
        await channel.bindQueue(q.queue, exchange, '');

        console.log("🏢 Admin waiting for announcements...");

        channel.consume(q.queue, (msg) => {
            if (msg !== null) {
                console.log("🏢 Admin received:", msg.content.toString());
                channel.ack(msg);
            }
        });

    } catch (error) {
        console.error("❌ Admin Error:", error);
    }
}

adminReceiver();

//publisher.js
const amqp = require('amqplib');

async function publishAnnouncement() {
    try {
        const connection = await amqp.connect('amqp://guest:guest@127.0.0.1:5672');
        const channel = await connection.createChannel();

        const exchange = 'announcements';

        const message = '📢 Important: College will remain closed tomorrow';

        // Create fanout exchange
        await channel.assertExchange(exchange, 'fanout', { durable: false });

        // Publish (routing key is ignored in fanout)
        channel.publish(exchange, '', Buffer.from(message));

        console.log("📤 Announcement Sent:", message);

        setTimeout(() => connection.close(), 500);

    } catch (error) {
        console.error("❌ Publisher Error:", error);
    }
}

publishAnnouncement();

